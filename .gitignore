# ───────── 시크릿 (절대 커밋 X) ─────────
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
*.pfx
*credentials*
*secret*
*.env.local
*.env.production

# ───────── 의존성 ─────────
node_modules/
client/dist/

# ───────── 런타임 데이터 ─────────
server/data/                       # 첨부 파일 저장소 (EC2 디스크에서만)
_ncs_data/_debug/
server/_debug/

# ───────── 서버 쪽 dev/probe/seed/migrate 스크립트 ─────────
# 로컬에서만 쓰는 일회성 스크립트들 (DB 접근 + 하드코딩 경로 포함)
server/_probe_*
server/scripts/
server/seed_*.js
server/migrate*.js
server/main.py

# ───────── 제안서 원본 (로컬 분석용, 사내 자료) ─────────
제안서데이터/
인력_양식체크리스트.xlsx
서버용_인력양식체크리스트.py

# ───────── Python 크롤링 probe (구버전, 로컬용) ─────────
crawl_g2b.py
probe_grid.py
run.bat
out/                               # 스크린샷·세션·테스트 덤프
NCS_채용대행_연도별수주현황.xlsx     # 사내 자료

# ───────── _ncs_data 작업 스크립트 ─────────
# JSON cache는 cron 동작에 필요하므로 유지, .py 작업 스크립트만 제외
_ncs_data/*.py
_ncs_data/*.html
_ncs_data/*.txt

# ───────── Python 백업 흔적 (이전 버전) ─────────
server-python-backup/
__pycache__/
*.pyc

# ───────── 임시 ─────────
*.log
.DS_Store
Thumbs.db
